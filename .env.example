# Option 1: fixed access token.
# Mercado Livre access tokens expire, so this is best for quick local testing.
MELI_ACCESS_TOKEN=

# Option 2: automatic in-memory refresh.
# Prefer this for normal MCP client usage.
MELI_CLIENT_ID=
MELI_CLIENT_SECRET=
MELI_REFRESH_TOKEN=

# Optional overrides.
MELI_API_BASE_URL=https://api.mercadolibre.com
MELI_TIMEOUT_MS=30000
MELI_USER_AGENT=mercadolivre-mcp-server/0.1.0
MELI_AUTH_BASE_URL=https://auth.mercadolivre.com.br
MELI_TOKEN_STORE_PATH=
